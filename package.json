{
  "name": "zedu-api-automation",
  "version": "1.0.0",
  "description": "API automation for Zedu Chat using Mocha + Axios",
  "scripts": {
    "test"
:
"mocha \"tests/**/*.test.js\" --timeout 30000 --reporter spec",
"test:ci"
:
"mocha \"tests/**/*.test.js\" --timeout 30000 --reporter mocha-junit-reporter --reporter-options mochaFile=./test-results/junit.xml"
  },
  "dependencies": {
    "@faker-js/faker": "^9.9.0",
    "axios": "^1.16.0",
    "chai": "^4.5.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "mocha": "^11.7.5",
    "mocha-junit-reporter": "^2.2.1",
    "mochawesome": "^7.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
